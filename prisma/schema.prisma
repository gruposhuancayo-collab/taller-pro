generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model cliente {
  id       Int      @id @default(autoincrement())
  nombre   String
  dni      String
  celular  String

  ordenes  orden[]
}

model orden {
  id        Int     @id @default(autoincrement())
  codigo    String

  producto  String
  marca     String
  modelo    String?
  serie     String?
  problema  String

  estado    String

  reparacion String?
  precio     Float?
  tipoPago   String?
  motivoNoReparado String?
  enGarantia Boolean @default(false)

  fechaIngreso  DateTime @default(now())
  fechaGarantia DateTime?

  deuda      Float? @default(0)

  fechaPago  DateTime?

  recibo     Int? @default(0)

  fotos      String[] @default([])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  clienteId Int
  cliente   cliente @relation(fields: [clienteId], references: [id])

  pagos     Pago[]
}

model Pago {
  id        Int      @id @default(autoincrement())
  ordenId   Int
  monto     Float
  metodo    String
  createdAt DateTime @default(now())

  orden orden @relation(fields: [ordenId], references: [id])
}

model ingresoExtra {
  id        Int      @id @default(autoincrement())
  detalle   String
  monto     Float
  createdAt DateTime @default(now())
}

model ProductoStock {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  precio      Float
  stock       Int      @default(0)

  imagenes    String[] @default([])

  createdAt   DateTime @default(now())
}